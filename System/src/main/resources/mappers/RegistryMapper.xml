<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.system.dao.RegistryDao">

    <select id="selectUserId" resultType="com.system.pojo.Registry">
        select id,username,password,tenant,delete_flag,dateTime,updateTime
        from registry
        where id=#{id}
    </select>

    <select id="selectUser" resultType="com.system.pojo.Registry">
        select id,username,password,tenant,delete_flag,dateTime,updateTime
        from registry
        where username=#{username}
    </select>

    <insert id="insertUser">
        insert into registry(id,username,password,tenant,delete_flag,dateTime,updateTime)
        values (#{id},#{username},#{password},#{tenant},#{deleteFlag},#{dateTime},#{updateTime})
    </insert>

</mapper>