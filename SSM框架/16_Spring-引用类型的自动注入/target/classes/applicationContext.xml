<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">


    <!--byName-->
    <bean id="myStudent" class="com.bjpowernode.dao.Student" autowire="byName">
        <property name="name" value="李晶晶"/>
        <property name="age" value="23"/>
        <!--
            <property name="school" ref="school"/>
            本来正常情况下是要写引用类型的set注入的，但是spring语句方便
            1、直接加上 autowire="byName",自己会在class="com.bjpowernode.domain.Student"
               这个类中寻找引用类型的引用school。
            2、然后我们在其它bean语句的id中找到对应的引用类型的引用。
            这种语句就叫做：引用类型的自动注入(byName)
        -->
    </bean>

    <bean id="school" class="com.bjpowernode.dao.School">
        <property name="name" value="武汉纺织大学外经贸学院"/>
        <property name="addrerss" value="商英"/>
    </bean>



