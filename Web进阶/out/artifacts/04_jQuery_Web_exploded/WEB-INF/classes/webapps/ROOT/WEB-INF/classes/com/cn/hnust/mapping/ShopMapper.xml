   	<select id="getCoupon" parameterType="com.cn.hnust.pojo.Qcoupon" resultMap="QcouponMapper">  
        select * from qcoupon where qdelete=0
        <if test="qshopid != null and qshopid != ''"> and qshopid = #{qshopid}  </if>
        <if test="id != null and id != ''"> and id = #{id}  </if>
        limit 0,200
    </select>
    
   	<insert id="saveCoupon" useGeneratedKeys="true" keyProperty="id" parameterType="com.cn.hnust.pojo.Qcoupon">  
